# ---- Database ----
POSTGRES_USER=parallel
POSTGRES_PASSWORD=parallel
POSTGRES_DB=parallel
# Used by the backend; host is the compose service name in containers, localhost otherwise.
DATABASE_URL=postgresql+psycopg2://parallel:parallel@db:5432/parallel

# ---- Flask ----
FLASK_SECRET_KEY=change-me-in-prod
# Where the browser reaches the API/frontend (used for OAuth redirect building)
PUBLIC_BASE_URL=http://localhost:5000
# Set to true ONLY when serving over HTTPS (prod behind TLS). Off for the http demo.
SESSION_COOKIE_SECURE=
SESSION_DAYS=30
# Rate limiting (auth endpoints). Point at redis for multi-process prod.
RATELIMIT_ENABLED=true
RATELIMIT_STORAGE_URI=memory://

# ---- Spotify (leave blank to run fully offline with the mock layer + dev-login) ----
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Must EXACTLY match a Redirect URI registered in your Spotify Developer dashboard.
SPOTIFY_REDIRECT_URI=http://localhost:5000/auth/callback

# ---- Frontend (dev) ----
# Vite proxies these prefixes to the backend in dev; in prod the API is same-origin.
VITE_API_BASE=
